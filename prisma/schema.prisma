// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VisionMapRecord {
  id          String   @id @default(cuid())
  title       String
  idea        String
  summary     String
  appsJson    String   @default("[]") // JSON array of app slugs
  nodesJson   String   // JSON array of VisionNode
  connectionsJson String @default("[]") // JSON array of VisionConnection
  palette     String   @default("anclora") // anclora | nexus | premium
  tags        String   @default("") // comma-separated tags
  starred     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([starred])
  @@index([createdAt])
}

model AncloraAppRecord {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  family        String   @default("Tool") // Premium | Internal | Tool | Platform
  tagline       String   @default("")
  description   String   @default("")
  stackJson     String   @default("[]") // JSON array of strings
  capabilitiesJson String @default("[]") // JSON array of strings
  accent        String   @default("#1dab89")
  domain        String   @default("")
  source        String   @default("manual") // manual | txt-import | github-import | default
  githubUrl     String?
  readme        String   @default("") // raw README content
  agentsMd      String   @default("") // raw AGENTS.md / MEMORY.md context
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([family])
  @@index([source])
}
