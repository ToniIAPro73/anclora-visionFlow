// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  viewer
  editor
  reviewer
  admin
}

enum CaseStatus {
  draft
  review
  approved
  handed_off
  archived
}

enum CaseType {
  captacion_premium
  comercializacion_activo
  contexto_energetico
  campana_territorial
  propuesta_partner
}

enum EvidenceSensitivity {
  public
  internal
  confidential
  restricted
}

enum EvidenceKind {
  manual
  datalab_insight_card
  energyscan_reference
  filestudio_manifest
}

enum DeliveryStatus {
  pending
  sent
  acknowledged
  failed
}

enum CatalogState {
  importado
  en_revision
  publicado
  retirado
}

enum AuditAction {
  import
  generation
  status_change
  export
  handoff
  catalog_publish
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         WorkspaceMember[]
  ownedMaps           VisionMapRecord[]  @relation("MapOwner")
  approvedMaps        VisionMapRecord[]  @relation("MapApprover")
  reviewedCatalogApps AncloraAppRecord[] @relation("CatalogReviewer")
}

model Workspace {
  id        String   @id
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     WorkspaceMember[]
  visionMaps  VisionMapRecord[]
  catalogApps AncloraAppRecord[]
  cases       Case[]
  caseMetrics CaseMetric[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole @default(viewer)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model VisionMapRecord {
  id          String   @id @default(cuid())
  title       String
  idea        String
  summary     String
  appsJson    String   @default("[]") // JSON array of app slugs
  nodesJson   String   // JSON array of VisionNode
  connectionsJson String @default("[]") // JSON array of VisionConnection
  palette     String   @default("anclora") // anclora | nexus | premium
  tags        String   @default("") // comma-separated tags
  starred     Boolean  @default(false)
  workspaceId String
  ownerId     String?
  status      String   @default("draft")
  approvedAt  DateTime?
  approvedById String?
  // AI generation traceability (REQ-AI-007, DES-AI-003)
  promptVersion String?
  llmModel     String?
  tokensUsed   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  owner      User?     @relation("MapOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  approvedBy User?     @relation("MapApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  exports    MapExport[]

  @@index([starred])
  @@index([createdAt])
  @@index([workspaceId, updatedAt])
  @@index([workspaceId, status])
  @@index([workspaceId, starred])
  @@index([ownerId])
  @@index([approvedById])
}

model AncloraAppRecord {
  id            String   @id @default(cuid())
  slug          String
  name          String
  family        String   @default("Tool") // Premium | Internal | Tool | Platform
  tagline       String   @default("")
  description   String   @default("")
  stackJson     String   @default("[]") // JSON array of strings
  capabilitiesJson String @default("[]") // JSON array of strings
  accent        String   @default("#1dab89")
  domain        String   @default("")
  source        String   @default("manual") // manual | txt-import | github-import | default
  githubUrl     String?
  readme        String   @default("") // raw README content
  agentsMd      String   @default("") // raw AGENTS.md / MEMORY.md context
  workspaceId   String
  reviewedById  String?
  reviewedAt    DateTime?
  status        String       @default("active")
  catalogState  CatalogState @default(importado)
  commitSha     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  reviewedBy User?     @relation("CatalogReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([workspaceId, slug])
  @@index([family])
  @@index([source])
  @@index([workspaceId, family])
  @@index([workspaceId, source])
  @@index([workspaceId, status])
  @@index([workspaceId, catalogState])
  @@index([reviewedById])
}

model MapExport {
  id        String   @id @default(cuid())
  mapId     String
  format    String   @db.VarChar(10) // "png", "pdf", "json"
  blobUrl   String   @db.Text
  blobHash  String   @unique // Vercel Blob ID for cleanup
  fileSize  Int      // bytes
  uploadedAt DateTime @default(now())
  expiresAt DateTime? // optional TTL for cleanup

  visionMap VisionMapRecord @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@index([uploadedAt])
  @@index([expiresAt])
}

model AuditEvent {
  id           String      @id @default(cuid())
  workspaceId  String
  actorId      String
  action       AuditAction
  resourceType String
  resourceId   String
  reason       String?
  metadata     Json?
  signature    String
  createdAt    DateTime    @default(now())

  @@index([workspaceId, action])
  @@index([resourceType, resourceId])
}

model Case {
  id            String      @id @default(cuid())
  workspaceId   String
  type          CaseType
  templateSlug  String
  title         String
  status        CaseStatus  @default(draft)
  brief         Json
  paletteId     String      @default("anclora")
  createdById   String
  reviewedById  String?
  approvedById  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  workspace     Workspace        @relation(fields: [workspaceId], references: [id])
  mapVersions   VisionMapVersion[]
  evidences     EvidenceReference[]
  briefExports  BriefExport[]
  sddExports    SddExport[]
  handoffDrafts HandoffDraft[]

  @@index([workspaceId, status])
  @@index([workspaceId, type])
}

model VisionMapVersion {
  id            String   @id @default(cuid())
  caseId        String
  version       Int
  map           Json
  promptVersion String?
  llmModel      String?
  tokensUsed    Int?
  createdAt     DateTime @default(now())

  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, version])
  @@index([caseId])
}

model EvidenceReference {
  id            String              @id @default(cuid())
  caseId        String
  source        String
  externalRef   String
  hash          String?
  sensitivity   EvidenceSensitivity @default(internal)
  kind          EvidenceKind        @default(manual)
  sourceVersion String?
  issuedAt      DateTime?
  expiresAt     DateTime?
  reviewState   String              @default("pending")
  createdAt     DateTime            @default(now())

  case          Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, sensitivity])
}

model BriefExport {
  id           String   @id @default(cuid())
  caseId       String
  workspaceId  String
  payload      Json
  target       String   @default("content-generator-ai")
  createdById  String
  createdAt    DateTime @default(now())

  case         Case @relation(fields: [caseId], references: [id])

  @@index([workspaceId, caseId])
}

model SddExport {
  id           String   @id @default(cuid())
  caseId       String
  workspaceId  String
  document     String
  prUrl        String?
  status       String   @default("generated")
  createdById  String
  createdAt    DateTime @default(now())

  case         Case @relation(fields: [caseId], references: [id])

  @@index([workspaceId, caseId])
}

model HandoffDraft {
  id             String   @id @default(cuid())
  caseId         String
  workspaceId    String
  payload        Json
  signature      String
  idempotencyKey String   @unique
  createdById    String
  confirmedById  String?
  createdAt      DateTime @default(now())

  case           Case                  @relation(fields: [caseId], references: [id])
  delivery       IntegrationDelivery?

  @@index([workspaceId, caseId])
}

model IntegrationDelivery {
  id             String         @id @default(cuid())
  handoffDraftId String         @unique
  target         String         @default("nexus")
  endpoint       String
  status         DeliveryStatus @default(pending)
  attempts       Int            @default(0)
  lastError      String?
  response       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  handoffDraft   HandoffDraft   @relation(fields: [handoffDraftId], references: [id])

  @@index([status])
}

/// Requires pgvector extension. Stores semantic embeddings for RAG.
model CatalogEmbedding {
  id            String   @id @default(cuid())
  sourceType    String   // "boveda_contract" | "realestate_spec" | "catalog_app"
  sourceId      String
  sourceVersion String
  chunk         String
  /// 384-dimension vector (open local embedding model)
  embedding     Unsupported("vector(384)")
  createdAt     DateTime @default(now())

  @@index([sourceType])
  @@index([sourceId])
}

model CaseMetric {
  id               String   @id @default(cuid())
  workspaceId      String
  caseId           String   @unique
  templateSlug     String
  reachedApproved  Boolean  @default(false)
  handedOff        Boolean  @default(false)
  reworkCount      Int      @default(0)
  evidenceCount    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace        Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, templateSlug])
  @@index([workspaceId])
}
